# sus Environment Configuration

# Database
DATABASE_URL=postgres://sus:sus@localhost:5433/sus

# Redis
REDIS_URL=redis://localhost:6379

# API Server
PORT=3000

# OpenCode Configuration
# The worker uses OpenCode CLI (https://github.com/anomalyco/opencode) for agentic threat detection
# and usage documentation generation. OpenCode will be auto-installed if not present.
#
# OpenCode uses ANTHROPIC_API_KEY for Claude API access. Set this here or in ~/.opencode/config
ANTHROPIC_API_KEY=

# CVE Enrichment (optional but recommended)
NVD_API_KEY=
GITHUB_TOKEN=

# Registry Watcher (sweep-based)
# Packages checked per minute (rate limit to avoid API limits)
PACKAGES_PER_MINUTE=100

# CVE Worker
CVE_POLL_INTERVAL_MINS=15

# Logging
RUST_LOG=info
